generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  CREATIVE_DIR
  HEAD_PROD
  HEAD_CREATIVE
  HEAD_MEDIA
  HEAD_COMMS
  COLLABORATOR
}

enum ProjectType {
  SHORT_FILM
  FEATURE_FILM
  STAGE_PRODUCTION
  PODCAST
  DOCUMENTARY
  MUSIC_VIDEO
  COMMERCIAL
}

enum ProjectStatus {
  DEVELOPMENT
  PRE_PRODUCTION
  PRODUCTION
  POST_PRODUCTION
  DISTRIBUTION
  ARCHIVED
}

enum ScriptType {
  SCREENPLAY
  AV_SCRIPT
  DOCUMENT
  TEMPLATE
}

enum ElementCategory {
  CAST
  EXTRAS
  PROPS
  SET_DRESSING
  WARDROBE
  MAKEUP
  VFX
  SOUND
  VEHICLES
  ANIMALS
  SPECIAL_EQUIPMENT
}

enum StripStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  POSTPONED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CallSheetStatus {
  DRAFT
  SENT
  CONFIRMED
}

enum ShotSize {
  ECU
  CU
  MCU
  MS
  MLS
  LS
  ELS
}

// ─── USERS ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      UserRole @default(COLLABORATOR)
  avatar    String?
  bio       String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectMembers ProjectMember[]
  assignedTasks  Task[]          @relation("AssignedTasks")
  createdTasks   Task[]          @relation("CreatedTasks")
  comments       Comment[]
  scriptLocks    Script[]        @relation("LockedScripts")
  scriptVersions ScriptVersion[]
  callSheetsSent CallSheet[]     @relation("SentCallSheets")

  @@map("users")
}

// ─── PROJECTS ─────────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  title       String
  type        ProjectType
  status      ProjectStatus @default(DEVELOPMENT)
  description String?
  logline     String?
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  spent       Float?        @default(0)
  coverImage  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members     ProjectMember[]
  scripts     Script[]
  breakdowns  Breakdown[]
  schedules   Schedule[]
  moodBoards  MoodBoard[]
  shotLists   ShotList[]
  storyboards Storyboard[]
  callSheets  CallSheet[]
  tasks       Task[]
  calendars   Calendar[]
  contacts    ProjectContact[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String?
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

// ─── WORD ROOM ────────────────────────────────────────────────────────────────

model Script {
  id            String     @id @default(cuid())
  projectId     String
  title         String
  type          ScriptType @default(SCREENPLAY)
  content       Json       @default("{}")
  version       Int        @default(1)
  revisionColor String?
  isLocked      Boolean    @default(false)
  lockedById    String?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lockedBy   User?           @relation("LockedScripts", fields: [lockedById], references: [id])
  versions   ScriptVersion[]
  breakdowns Breakdown[]

  @@map("scripts")
}

model ScriptVersion {
  id            String   @id @default(cuid())
  scriptId      String
  version       Int
  content       Json
  revisionColor String?
  notes         String?
  createdAt     DateTime @default(now())
  createdById   String

  script    Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  createdBy User   @relation(fields: [createdById], references: [id])

  @@map("script_versions")
}

// ─── BREAKDOWN ROOM ───────────────────────────────────────────────────────────

model Breakdown {
  id        String   @id @default(cuid())
  projectId String
  scriptId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  script  Script  @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  scenes  Scene[]

  @@map("breakdowns")
}

model Scene {
  id           String  @id @default(cuid())
  breakdownId  String
  sceneNumber  String
  heading      String
  synopsis     String?
  pageCount    Float   @default(1)
  storyDay     Int?
  prepMinutes  Int?
  shootMinutes Int?
  intExt       String? // INT | EXT | INT/EXT
  timeOfDay    String? // DAY | NIGHT | DAWN | DUSK
  location     String?
  order        Int     @default(0)

  breakdown Breakdown      @relation(fields: [breakdownId], references: [id], onDelete: Cascade)
  elements  SceneElement[]
  strips    Strip[]

  @@map("scenes")
}

model SceneElement {
  id          String          @id @default(cuid())
  sceneId     String
  category    ElementCategory
  name        String
  notes       String?
  aiSuggested Boolean         @default(false)
  confirmed   Boolean         @default(true)

  scene Scene @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@map("scene_elements")
}

// ─── SCHEDULE ROOM ────────────────────────────────────────────────────────────

model Schedule {
  id        String   @id @default(cuid())
  projectId String
  name      String   @default("Version A")
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shootDays ShootDay[]

  @@map("schedules")
}

model ShootDay {
  id              String    @id @default(cuid())
  scheduleId      String
  dayNumber       Int
  date            DateTime?
  generalCallTime String?
  location        String?
  notes           String?
  isWrapDay       Boolean   @default(false)

  schedule   Schedule    @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  strips     Strip[]
  callSheets CallSheet[]

  @@map("shoot_days")
}

model Strip {
  id               String      @id @default(cuid())
  shootDayId       String
  sceneId          String
  order            Int         @default(0)
  status           StripStatus @default(NOT_STARTED)
  estimatedMinutes Int?
  notes            String?

  shootDay ShootDay @relation(fields: [shootDayId], references: [id], onDelete: Cascade)
  scene    Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@map("strips")
}

// ─── VISION ROOM ──────────────────────────────────────────────────────────────

model MoodBoard {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  group       String?
  description String?
  shareToken  String?  @unique @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items   MoodBoardItem[]

  @@map("mood_boards")
}

model MoodBoardItem {
  id          String  @id @default(cuid())
  moodBoardId String
  imageUrl    String
  caption     String?
  aiGenerated Boolean @default(false)
  order       Int     @default(0)
  width       Int?
  height      Int?

  moodBoard MoodBoard @relation(fields: [moodBoardId], references: [id], onDelete: Cascade)

  @@map("mood_board_items")
}

model ShotList {
  id        String   @id @default(cuid())
  projectId String
  title     String
  sceneRef  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shots   Shot[]

  @@map("shot_lists")
}

model Shot {
  id          String   @id @default(cuid())
  shotListId  String
  shotNumber  String
  description String
  shotSize    String?
  angle       String?
  lens        String?
  movement    String?
  frameRate   String?
  duration    String?
  notes       String?
  imageUrl    String?
  aiGenerated Boolean  @default(false)
  order       Int      @default(0)

  shotList ShotList @relation(fields: [shotListId], references: [id], onDelete: Cascade)

  @@map("shots")
}

model Storyboard {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  aspectRatio String   @default("16:9")
  notes       String?
  shareToken  String?  @unique @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  panels  StoryboardPanel[]

  @@map("storyboards")
}

model StoryboardPanel {
  id           String  @id @default(cuid())
  storyboardId String
  panelNumber  Int
  imageUrl     String?
  description  String?
  audioNote    String?
  cameraNote   String?
  aiGenerated  Boolean @default(false)
  order        Int     @default(0)

  storyboard Storyboard @relation(fields: [storyboardId], references: [id], onDelete: Cascade)

  @@map("storyboard_panels")
}

// ─── CALL ROOM ────────────────────────────────────────────────────────────────

model Contact {
  id             String   @id @default(cuid())
  name           String
  role           String
  department     String?
  email          String?
  phone          String?
  whatsapp       String?
  dayRate        Float?
  currency       String   @default("KES")
  emergencyName  String?
  emergencyPhone String?
  dietary        String?
  transport      String?
  tshirtSize     String?
  notes          String?
  avatarUrl      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lists       ContactListMember[]
  callEntries CallSheetEntry[]
  projects    ProjectContact[]

  @@map("contacts")
}

model ContactList {
  id        String   @id @default(cuid())
  name      String
  projectId String?
  createdAt DateTime @default(now())

  members ContactListMember[]

  @@map("contact_lists")
}

model ContactListMember {
  id            String @id @default(cuid())
  contactListId String
  contactId     String

  contactList ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)
  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactListId, contactId])
  @@map("contact_list_members")
}

model ProjectContact {
  id        String @id @default(cuid())
  projectId String
  contactId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([projectId, contactId])
  @@map("project_contacts")
}

model CallSheet {
  id              String          @id @default(cuid())
  projectId       String
  shootDayId      String?
  dayNumber       Int
  date            DateTime
  generalCallTime String
  location        String
  locationAddress String?
  locationGps     String?
  nearestHospital String?
  parking         String?
  weather         String?
  advanceSchedule String?
  prayerFocus     Json?
  status          CallSheetStatus @default(DRAFT)
  sentAt          DateTime?
  sentById        String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shootDay  ShootDay?        @relation(fields: [shootDayId], references: [id])
  sentBy    User?            @relation("SentCallSheets", fields: [sentById], references: [id])
  entries   CallSheetEntry[]

  @@map("call_sheets")
}

model CallSheetEntry {
  id             String   @id @default(cuid())
  callSheetId    String
  contactId      String
  callTime       String
  onSetTime      String?
  makeupTime     String?
  notes          String?
  deliveryStatus String?
  openedAt       DateTime?

  callSheet CallSheet @relation(fields: [callSheetId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("call_sheet_entries")
}

// ─── COMMAND ROOM ─────────────────────────────────────────────────────────────

model Task {
  id          String     @id @default(cuid())
  projectId   String
  title       String
  description String?
  assigneeId  String?
  createdById String?
  dueDate     DateTime?
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(TODO)
  board       String?
  order       Int        @default(0)
  attachments String[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   User?       @relation("AssignedTasks", fields: [assigneeId], references: [id])
  createdBy  User?       @relation("CreatedTasks", fields: [createdById], references: [id])
  checklists Checklist[]
  comments   Comment[]

  @@map("tasks")
}

model Checklist {
  id        String   @id @default(cuid())
  taskId    String
  title     String
  completed Boolean  @default(false)
  order     Int      @default(0)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("checklists")
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("comments")
}

model Calendar {
  id        String   @id @default(cuid())
  projectId String
  name      String
  group     String?
  color     String?
  createdAt DateTime @default(now())

  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events  CalendarEvent[]

  @@map("calendars")
}

model CalendarEvent {
  id          String    @id @default(cuid())
  calendarId  String
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  allDay      Boolean   @default(false)
  color       String?
  dependsOn   String?
  createdAt   DateTime  @default(now())

  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@map("calendar_events")
}